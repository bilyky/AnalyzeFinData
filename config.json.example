{
  "chaikin": {
    "email": "your_chaikin_email@example.com",
    "password": "your_chaikin_password"
  },
  "etrade": {
    "username": "your_etrade_username",
    "password": "your_etrade_password",
    "proxy": "",
    "sandbox": {
      "consumer_key": "your_sandbox_consumer_key",
      "consumer_secret": "your_sandbox_consumer_secret"
    },
    "production": {
      "consumer_key": "your_production_consumer_key",
      "consumer_secret": "your_production_consumer_secret"
    }
  },
  "rapidapi": {
    "api_key": "your_rapidapi_key_here"
  },
  "email_intel": {
    "mailboxes": [
      {
        "email": "primary_newsletters@example.com",
        "password_env": "SMTP_PASSWORD",
        "imap_server": "imap.gmail.com"
      },
      {
        "email": "secondary_alerts@example.com",
        "password_env": "SMTP_PASSWORD_ALT",
        "imap_server": "imap.gmail.com"
      }
    ]
  },
  "email_sender": {
    "password": "your_gmail_app_password_here"
  },
  "accounts": {
    "real": ["XXXX", "YYYY"]
  },
  "ai": {
    "primary": "github_gpt",
    "max_intel_emails": 20,
    "providers": {
      "github_gpt": {
        "_note": "Free via GitHub personal access token — github.com/settings/tokens. Set GITHUB_TOKEN env var or paste the ghp_... token as api_key_source literal.",
        "enabled": true,
        "type": "openai_compatible",
        "model": "gpt-4o-mini",
        "endpoint": "https://models.inference.ai.azure.com/chat/completions",
        "api_key_source": "env:GITHUB_TOKEN"
      },
      "gemini_oai": {
        "_note": "Free tier via Google AI Studio — aistudio.google.com. Get GEMINI_API_KEY there (no credit card). Uses OpenAI-compatible REST so no extra dependencies.",
        "enabled": false,
        "type": "openai_compatible",
        "model": "gemini-2.5-flash",
        "endpoint": "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions",
        "api_key_source": "env:GEMINI_API_KEY"
      },
      "claude": {
        "_note": "Anthropic API — console.anthropic.com. Set ANTHROPIC_API_KEY env var.",
        "enabled": false,
        "type": "anthropic",
        "model": "claude-opus-4-8",
        "api_key_source": "env:ANTHROPIC_API_KEY"
      },
      "gemini_cli": {
        "_note": "Gemini via the gemini CLI binary (gemini.google.com/app — install gemini CLI). No API key needed but requires the CLI installed.",
        "enabled": false,
        "type": "gemini_cli",
        "model": "gemini-2.5-flash"
      }
    }
  },
  "web": {
    "port": 8888,
    "host": "0.0.0.0",
    "secret": "long_random_string_for_signing_session_tokens",
    "admins": [
      { "user": "admin", "pass": "change_me" }
    ]
  }
}
